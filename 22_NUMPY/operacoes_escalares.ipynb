    "import numpy as np\n",
    "dados = np.array([100, 200, 300, 400])\n",
    "\n",
    "print('Adiconando 10:', dados + 10)\n",
    "print('Multiplicando:', dados * 10)\n",
    "print('Dividindo:', dados / 5)\n",
    "print('Subtraindo:', dados - 10)\n",
    "print('Exponenciação:', dados**2)\n",
    "\n",
    "\n"
   ]
